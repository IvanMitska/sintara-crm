generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  SUPERVISOR
}

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  OPERATOR
}

enum ContactSource {
  WEBSITE
  PHONE
  EMAIL
  WHATSAPP
  INSTAGRAM
  TELEGRAM
  VK
  REFERRAL
  DIRECT
  OTHER
}

enum DealPriority {
  LOW
  MEDIUM
  HIGH
}

enum DealTemperature {
  HOT
  WARM
  COLD
}

enum DealStatus {
  NEW
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CONTRACT
  PAYMENT
  SUCCESS
  LOST
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  QUALIFIED
  CONVERTED
  LOST
}

enum LeadSource {
  WEBSITE
  CALL
  EMAIL
  SOCIAL
  TELEGRAM
  WHATSAPP
  REFERRAL
  OTHER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum ResourceType {
  SPECIALIST
  ROOM
  EQUIPMENT
  VEHICLE
  OTHER
}

enum ResourceCategory {
  MEDICAL
  EQUIPMENT_RENTAL
  SERVICES
  CARS
  ROOMS
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum WaitingListStatus {
  WAITING
  CONTACTED
  BOOKED
  CANCELLED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  currency  String   @default("THB") // THB, RUB, USD, EUR
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      OrgMember[]
  contacts     Contact[]
  companies    Company[]
  leads        Lead[]
  deals        Deal[]
  pipelines    Pipeline[]
  products     Product[]
  tasks        Task[]
  activities   Activity[]
  messages     Message[]
  tags         Tag[]
  automations  Automation[]
  invitations  Invitation[]
  resources    Resource[]
  services     Service[]
  bookings     Booking[]
  waitingList  WaitingListItem[]
  integrations IntegrationConfig[]
  webhooks     Webhook[]

  @@index([slug])
}

model OrgMember {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrgRole       @default(OPERATOR)
  isActive       Boolean       @default(true)
  joinedAt       DateTime      @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  firstName        String
  lastName         String
  middleName       String?
  phone            String?
  avatar           String?
  role             UserRole  @default(OPERATOR)
  isActive         Boolean   @default(true)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  lastActivityAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  refreshTokens       RefreshToken[]
  createdInvitations  Invitation[]   @relation("InvitationCreator")
  acceptedInvitations Invitation[]   @relation("InvitationAcceptor")
  memberships         OrgMember[]
  teams               TeamMember[]
  ownedContacts       Contact[]      @relation("ContactOwner")
  createdContacts     Contact[]      @relation("ContactCreator")
  ownedCompanies      Company[]      @relation("CompanyOwner")
  createdCompanies    Company[]      @relation("CompanyCreator")
  ownedDeals          Deal[]         @relation("DealOwner")
  createdDeals        Deal[]         @relation("DealCreator")
  tasks               Task[]         @relation("TaskAssignee")
  createdTasks        Task[]         @relation("TaskCreator")
  ownedLeads          Lead[]         @relation("LeadOwner")
  createdLeads        Lead[]         @relation("LeadCreator")
  activities          Activity[]
  notifications       Notification[]
  messages            Message[]
  createdBookings     Booking[]      @relation("BookingCreator")
  createdWebhooks     Webhook[]

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Invitation {
  id        String           @id @default(cuid())
  email     String
  role      OrgRole          @default(OPERATOR)
  token     String           @unique @default(cuid())
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  invitedById String
  invitedBy   User   @relation("InvitationCreator", fields: [invitedById], references: [id])

  acceptedById String?
  acceptedBy   User?   @relation("InvitationAcceptor", fields: [acceptedById], references: [id])

  createdAt  DateTime  @default(now())
  acceptedAt DateTime?

  @@index([email])
  @@index([token])
  @@index([status])
  @@index([organizationId])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members TeamMember[]

  @@index([name])
}

model TeamMember {
  id       String   @id @default(cuid())
  userId   String
  teamId   String
  isLead   Boolean  @default(false)
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
}

model Contact {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  middleName   String?
  email        String?
  phone        String?
  secondPhone  String?
  position     String?
  birthDate    DateTime?
  source       ContactSource @default(DIRECT)
  description  String?
  tags         Tag[]
  customFields Json?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  ownerId String
  owner   User   @relation("ContactOwner", fields: [ownerId], references: [id])

  createdById String
  createdBy   User   @relation("ContactCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals         Deal[]
  tasks         Task[]
  activities    Activity[]
  messages      Message[]
  bookings      Booking[]
  waitingList   WaitingListItem[]
  telegramChats TelegramChat[]
  whatsappChats WhatsAppChat[]
  emailMessages EmailMessage[]

  @@index([email])
  @@index([phone])
  @@index([companyId])
  @@index([ownerId])
  @@index([source])
  @@index([organizationId])
}

model Company {
  id           String  @id @default(cuid())
  name         String
  inn          String?
  kpp          String?
  ogrn         String?
  website      String?
  email        String?
  phone        String?
  address      String?
  description  String?
  industry     String?
  size         String?
  tags         Tag[]
  customFields Json?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User   @relation("CompanyOwner", fields: [ownerId], references: [id])

  createdById String
  createdBy   User   @relation("CompanyCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts Contact[]
  deals    Deal[]

  @@index([name])
  @@index([inn])
  @@index([ownerId])
  @@index([organizationId])
}

model Lead {
  id          String     @id @default(cuid())
  name        String
  email       String?
  phone       String?
  company     String?
  source      LeadSource @default(WEBSITE)
  status      LeadStatus @default(NEW)
  description String?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  ownerId String?
  owner   User?   @relation("LeadOwner", fields: [ownerId], references: [id])

  createdById String
  createdBy   User   @relation("LeadCreator", fields: [createdById], references: [id])

  convertedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([source])
  @@index([ownerId])
  @@index([createdAt])
  @@index([organizationId])
}

model Pipeline {
  id          String  @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean @default(false)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stages    Stage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([organizationId])
}

model Stage {
  id         String   @id @default(cuid())
  name       String
  color      String   @default("#3B82F6")
  order      Int
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  deals Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pipelineId, order])
  @@index([pipelineId])
}

model Deal {
  id             String           @id @default(cuid())
  title          String
  amount         Decimal          @db.Decimal(15, 2)
  currency       String           @default("RUB")
  probability    Int              @default(50)
  expectedDate   DateTime?
  status         DealStatus       @default(NEW)
  priority       DealPriority     @default(MEDIUM)
  temperature    DealTemperature?
  tags           String[]         @default([])
  lastActivityAt DateTime?
  description    String?
  customFields   Json?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stageId String
  stage   Stage  @relation(fields: [stageId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  ownerId String
  owner   User   @relation("DealOwner", fields: [ownerId], references: [id])

  createdById String
  createdBy   User   @relation("DealCreator", fields: [createdById], references: [id])

  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products   DealProduct[]
  tasks      Task[]
  activities Activity[]

  @@index([status])
  @@index([stageId])
  @@index([contactId])
  @@index([companyId])
  @@index([ownerId])
  @@index([organizationId])
}

model Product {
  id          String  @id @default(cuid())
  name        String
  sku         String?
  description String?
  price       Decimal @db.Decimal(15, 2)
  currency    String  @default("RUB")
  unit        String  @default("шт")
  isActive    Boolean @default(true)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealProducts DealProduct[]

  @@index([name])
  @@index([sku])
  @@index([organizationId])
}

model DealProduct {
  id        String  @id @default(cuid())
  dealId    String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(15, 2)
  discount  Decimal @default(0) @db.Decimal(5, 2)

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([dealId, productId])
  @@index([dealId])
  @@index([productId])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(PENDING)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assigneeId String
  assignee   User   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  createdById String
  createdBy   User   @relation("TaskCreator", fields: [createdById], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@index([contactId])
  @@index([dealId])
  @@index([dueDate])
  @@index([organizationId])
}

model Activity {
  id          String @id @default(cuid())
  type        String
  description String
  metadata    Json?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([type])
  @@index([userId])
  @@index([contactId])
  @@index([dealId])
  @@index([createdAt])
  @@index([organizationId])
}

model Message {
  id        String  @id @default(cuid())
  channel   String
  direction String
  content   String
  metadata  Json?
  isRead    Boolean @default(false)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([channel])
  @@index([contactId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([organizationId])
}

model Tag {
  id    String @id @default(cuid())
  name  String
  color String @default("#6B7280")

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contacts  Contact[]
  companies Company[]
  createdAt DateTime  @default(now())

  @@unique([organizationId, name])
  @@index([name])
  @@index([organizationId])
}

model Notification {
  id       String  @id @default(cuid())
  type     String
  title    String
  content  String
  isRead   Boolean @default(false)
  metadata Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}

model Automation {
  id          String  @id @default(cuid())
  name        String
  description String?
  trigger     Json
  conditions  Json?
  actions     Json
  isActive    Boolean @default(true)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  lastRunAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive])
  @@index([name])
  @@index([organizationId])
}

// ============ Booking Module ============

model Resource {
  id          String           @id @default(cuid())
  name        String
  type        ResourceType     @default(SPECIALIST)
  category    ResourceCategory @default(SERVICES)
  color       String           @default("#3B82F6")
  avatar      String?
  description String?
  workingHours Json?           // e.g., {"mon": {"start": "09:00", "end": "18:00"}, ...}
  breakTime   Json?            // e.g., {"start": "13:00", "end": "14:00"}
  slotDuration Int             @default(60) // in minutes
  isActive    Boolean          @default(true)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services    ResourceService[]
  bookings    Booking[]
  waitingList WaitingListItem[]

  @@index([type])
  @@index([category])
  @@index([isActive])
  @@index([organizationId])
}

model Service {
  id          String  @id @default(cuid())
  name        String
  description String?
  duration    Int     @default(60) // in minutes
  price       Decimal @db.Decimal(15, 2)
  currency    String  @default("RUB")
  color       String  @default("#8B5CF6")
  isActive    Boolean @default(true)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resources   ResourceService[]
  bookings    Booking[]
  waitingList WaitingListItem[]

  @@index([name])
  @@index([isActive])
  @@index([organizationId])
}

model ResourceService {
  id         String @id @default(cuid())
  resourceId String
  serviceId  String

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, serviceId])
  @@index([resourceId])
  @@index([serviceId])
}

model Booking {
  id          String        @id @default(cuid())
  title       String?
  description String?
  startTime   DateTime
  endTime     DateTime
  status      BookingStatus @default(PENDING)
  color       String?
  notes       String?
  metadata    Json?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("BookingCreator", fields: [createdById], references: [id], onDelete: SetNull)

  confirmedAt       DateTime?
  cancelledAt       DateTime?
  cancellationReason String?
  completedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([startTime])
  @@index([endTime])
  @@index([resourceId])
  @@index([serviceId])
  @@index([contactId])
  @@index([organizationId])
}

model WaitingListItem {
  id String @id @default(cuid())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  resourceId String?
  resource   Resource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  preferredDateFrom DateTime?
  preferredDateTo   DateTime?
  preferredTimeFrom String?   // e.g., "09:00"
  preferredTimeTo   String?   // e.g., "18:00"
  notes             String?
  status            WaitingListStatus @default(WAITING)

  contactedAt DateTime?
  bookedAt    DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([contactId])
  @@index([resourceId])
  @@index([organizationId])
}

// ============ Integrations ============

enum IntegrationType {
  TELEGRAM
  WHATSAPP
  INSTAGRAM
  VK
  EMAIL
}

model IntegrationConfig {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type      IntegrationType
  name      String           // Display name (e.g., "Основной бот")
  isActive  Boolean          @default(true)

  // Encrypted credentials stored as JSON
  // For Telegram: { botToken: "...", webhookSecret: "..." }
  // For WhatsApp: { apiKey: "...", phoneNumberId: "..." }
  credentials Json?

  // Additional settings
  settings Json? // { welcomeMessage: "...", autoReply: true, ... }

  // Webhook URL (auto-generated)
  webhookUrl    String?
  webhookSecret String?

  // Stats
  messagesReceived Int @default(0)
  messagesSent     Int @default(0)
  lastActivityAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  telegramChats TelegramChat[]
  whatsappChats WhatsAppChat[]
  emailAccounts EmailAccount[]

  @@unique([organizationId, type, name])
  @@index([organizationId])
  @@index([type])
  @@index([isActive])
}

model TelegramChat {
  id String @id @default(cuid())

  integrationId String
  integration   IntegrationConfig @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  // Telegram data
  telegramChatId   String // Telegram chat ID (can be user ID or group ID)
  telegramUsername String?
  telegramFirstName String?
  telegramLastName  String?
  chatType         String  @default("private") // private, group, supergroup, channel

  // Link to CRM contact (optional - can be auto-created or manually linked)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  // Last message info for display
  lastMessageAt DateTime?

  isBlocked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([integrationId, telegramChatId])
  @@index([contactId])
  @@index([telegramChatId])
}

model WhatsAppChat {
  id String @id @default(cuid())

  integrationId String
  integration   IntegrationConfig @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  // WhatsApp data
  waId          String  // WhatsApp ID (phone number without +)
  phoneNumber   String  // Full phone number with country code
  displayName   String? // Profile name from WhatsApp
  profilePicUrl String? // Profile picture URL

  // Link to CRM contact (optional - can be auto-created or manually linked)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  // Conversation window tracking (WhatsApp 24h window)
  lastInboundAt  DateTime? // Last message from user (resets 24h window)
  windowExpiresAt DateTime? // When the 24h window expires

  // Last message info for display
  lastMessageAt DateTime?

  isBlocked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([integrationId, waId])
  @@index([contactId])
  @@index([waId])
  @@index([phoneNumber])
}

// Email IMAP Integration
model EmailAccount {
  id String @id @default(cuid())

  integrationId String
  integration   IntegrationConfig @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  // Account info
  email       String // Email address
  displayName String? // Display name for the account

  // IMAP settings (encrypted in credentials JSON in IntegrationConfig)
  // Settings stored here are non-sensitive
  imapHost    String
  imapPort    Int     @default(993)
  imapSecure  Boolean @default(true)

  // SMTP settings for sending
  smtpHost    String?
  smtpPort    Int?    @default(587)
  smtpSecure  Boolean @default(false)

  // Sync settings
  syncEnabled   Boolean   @default(true)
  lastSyncAt    DateTime?
  lastSyncError String?
  syncFolder    String    @default("INBOX") // IMAP folder to sync

  // Stats
  emailsReceived Int @default(0)
  emailsSent     Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailMessages EmailMessage[]

  @@unique([integrationId, email])
  @@index([email])
}

model EmailMessage {
  id String @id @default(cuid())

  emailAccountId String
  emailAccount   EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)

  // Email identifiers
  messageId   String  // IMAP Message-ID header
  uid         Int?    // IMAP UID
  threadId    String? // For threading (In-Reply-To / References)

  // Email headers
  fromEmail   String
  fromName    String?
  toEmails    String[] // Array of recipient emails
  ccEmails    String[] // Array of CC emails
  bccEmails   String[] // Array of BCC emails
  replyTo     String?
  subject     String?

  // Content
  textBody    String? // Plain text body
  htmlBody    String? // HTML body
  snippet     String? // Short preview

  // Attachments stored as JSON array
  // [{ filename: "doc.pdf", mimeType: "application/pdf", size: 12345, cid: "...", url: "..." }]
  attachments Json?

  // Flags
  isRead      Boolean @default(false)
  isStarred   Boolean @default(false)
  isArchived  Boolean @default(false)
  isDraft     Boolean @default(false)
  isSent      Boolean @default(false) // true = outbound, false = inbound
  isDeleted   Boolean @default(false)

  // Link to CRM contact (auto-matched by email)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  // Original email date
  emailDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([emailAccountId, messageId])
  @@index([contactId])
  @@index([fromEmail])
  @@index([emailDate])
  @@index([isRead])
  @@index([threadId])
}

// Webhook System
enum WebhookEvent {
  // Contact events
  CONTACT_CREATED
  CONTACT_UPDATED
  CONTACT_DELETED
  
  // Deal events
  DEAL_CREATED
  DEAL_UPDATED
  DEAL_DELETED
  DEAL_STATUS_CHANGED
  DEAL_WON
  DEAL_LOST
  
  // Task events
  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_DELETED
  
  // Lead events
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_CONVERTED
  LEAD_DELETED
  
  // Message events
  MESSAGE_RECEIVED
  MESSAGE_SENT
  
  // Company events
  COMPANY_CREATED
  COMPANY_UPDATED
  COMPANY_DELETED
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  FAILED
}

model Webhook {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Webhook configuration
  name        String
  description String?
  url         String    // Endpoint URL to send events to
  secret      String?   // Secret for HMAC signature verification
  
  // Events to subscribe to
  events      WebhookEvent[]
  
  // Status
  status      WebhookStatus @default(ACTIVE)
  
  // Retry configuration
  maxRetries  Int       @default(3)
  retryDelay  Int       @default(60) // seconds between retries
  
  // Headers to include in requests (JSON)
  headers     Json?
  
  // Stats
  totalDeliveries   Int @default(0)
  successDeliveries Int @default(0)
  failedDeliveries  Int @default(0)
  lastDeliveryAt    DateTime?
  lastError         String?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Created by
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  deliveries WebhookDelivery[]

  @@index([organizationId])
  @@index([status])
}

model WebhookDelivery {
  id String @id @default(cuid())

  webhookId String
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  // Event details
  event     WebhookEvent
  payload   Json          // Full event payload
  
  // Delivery status
  success   Boolean
  attempts  Int      @default(1)
  
  // Response details
  statusCode    Int?
  responseBody  String?
  responseTime  Int?     // Response time in ms
  error         String?
  
  // Timestamps
  createdAt     DateTime @default(now())
  deliveredAt   DateTime?
  nextRetryAt   DateTime?

  @@index([webhookId])
  @@index([event])
  @@index([createdAt])
  @@index([success])
}
